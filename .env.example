# --- Core ---
# OpenRouter BYOK for AI decision layer. Model string is current MiniMax model on OpenRouter.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=minimax/minimax-m2

# --- Messaging / Storage ---
REDIS_URL=redis://redis:6379/0
TIMESCALEDB_URL=postgresql+asyncpg://xauusd:xauusd@timescaledb:5432/xauusd

# --- Connector mode ---
# Options: replay | live
CONNECTOR_MODE=replay

# --- News / Macro Calendar Provider ---
# Options: tradingeconomics | fxstreet | stub
NEWS_API_PROVIDER=stub
NEWS_API_KEY=

# --- Vantage MT5 (PROD only, used by mt5-terminal container) ---
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=VantageInternational-Demo
VANTAGE_DATA_DIR=/var/lib/xauusd/vantage

# --- Instrument / Risk ---
SYMBOL=XAUUSD
RISK_MAX_DAILY=0.04
RISK_MAX_WEEKLY=0.08

# --- Service selection (used by docker/service entrypoint) ---
# Options: data-collector | feature-engine | decision-engine | execution-engine | review
SERVICE_ROLE=data-collector

# --- Misc ---
LOG_LEVEL=INFO
ENVIRONMENT=development

# --- Web-Dashboard (Block 9) ---
# Enable/disable the Custom Web-Dashboard. Default off — must be
# explicitly true to serve traffic on 127.0.0.1:8080.
# See AGENTS.md §4j for the full list of dashboard caveats.
DASHBOARD_ENABLED=false
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8080
# Generate bcrypt hash with:
#   .venv/bin/python -c "import bcrypt; print(bcrypt.hashpw(b'my_pw', bcrypt.gensalt()).decode())"
# Roles: viewer (read-only), operator (approve proposals + backtest), admin (Live-Mode-Toggle)
DASHBOARD_USERS={"lucas": {"password_hash": "$2b$12$...", "role": "admin"}}
DASHBOARD_SESSION_TTL_SECONDS=28800
# Dashboard sessions live on Redis DB 1, trading streams stay on /0.
DASHBOARD_REDIS_URL=redis://redis:6379/1
DASHBOARD_REDIS_STREAMS_URL=redis://redis:6379/0
# Set true to enable the Live-Mode-Toggle button (admin role required).
DASHBOARD_LIVE_MODE_ENABLED=false
