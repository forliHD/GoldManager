# --- Core ---
# OpenRouter BYOK for AI decision layer. Model string is current MiniMax model on OpenRouter.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=minimax/minimax-m3
# Provider routing: pin OpenRouter to MiniMax's own endpoint so your BYOK
# reaches MiniMax instead of OpenRouter picking a reseller. Comma-separated
# provider slugs (see the model's /endpoints); empty = no pin.
OPENROUTER_PROVIDER_ORDER=minimax/fp8
# If false, OpenRouter must use a provider above (no fallback to others).
OPENROUTER_ALLOW_FALLBACKS=false
# Zero-Data-Retention. OFF by default: MiniMax's endpoint (minimax/fp8) is
# NOT ZDR-certified, so zdr=true + the MiniMax pin returns 404 "no endpoints".
# provider.data_collection="deny" is sent regardless. Enable only with a
# ZDR-listed model + OPENROUTER_ALLOW_FALLBACKS=true (may bypass your BYOK).
AI_LAYER_ZDR=false

# --- Messaging / Storage ---
REDIS_URL=redis://redis:6379/0
TIMESCALEDB_URL=postgresql+asyncpg://xauusd:xauusd@timescaledb:5432/xauusd

# --- Connector mode ---
# Options: replay | live
CONNECTOR_MODE=replay

# --- News / Macro Calendar Provider ---
# Options: tradingeconomics | fxstreet | stub
NEWS_API_PROVIDER=stub
NEWS_API_KEY=

# --- Vantage MT5 (mt5-terminal container; prod, or dev via docker-compose.mt5.yml) ---
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=VantageInternational-Demo
MT5_SYMBOL=XAUUSD
VANTAGE_DATA_DIR=/var/lib/xauusd/vantage
# VNC for the one-time MT5 terminal login (mt5-terminal container).
VNC_PASSWORD=changeme
# Host interface for the VNC/noVNC ports. 127.0.0.1 = loopback (use an SSH
# tunnel). Set 0.0.0.0 for direct LAN access (trusted network only).
MT5_VNC_BIND_HOST=127.0.0.1
# RPyC bridge the LiveMT5Connector talks to (the mt5-terminal container).
MT5_BRIDGE_HOST=mt5-terminal
MT5_BRIDGE_PORT=18812
# Optional shared secret if the bridge was started with MT5_BRIDGE_AUTH_KEY.
MT5_BRIDGE_AUTH_KEY=

# --- Instrument / Risk ---
SYMBOL=XAUUSD
RISK_MAX_DAILY=0.04
RISK_MAX_WEEKLY=0.08

# --- Service selection (used by docker/service entrypoint) ---
# Options: data-collector | feature-engine | decision-engine | execution-engine | journal-writer
# (review runs on-demand via CLI, not as a streaming service)
SERVICE_ROLE=data-collector

# --- Execution / trading-hours window ---
# Only OPEN new entries inside the volume window: Asian open (00:00 UTC) to just
# before the NY close (22:55 UTC; no volume after). Times are in
# EXEC_TRADING_TIMEZONE (UTC by default — set e.g. Europe/Berlin for a DST-adjusted
# local window). Blocks new entries only; a running trade may be held overnight.
# EXEC_WEEKEND_FLAT: never carry a position over the weekend — on Friday at/after
# EXEC_WEEKEND_FLAT_UTC the engine force-closes any open position (set it BEFORE
# your broker's Friday gold close so a flatten bar still fires).
EXEC_TRADING_WINDOW_ENABLED=true
EXEC_TRADING_START_LOCAL=00:00
EXEC_TRADING_END_LOCAL=22:55
EXEC_TRADING_TIMEZONE=UTC
EXEC_WEEKEND_FLAT_ENABLED=true
EXEC_WEEKEND_FLAT_UTC=20:55

# --- Exit management: let winners run (Phase D) ---
# Trailing SL sits this many ATR BEHIND the protective swing (was 1×ATR ABOVE,
# which choked runners into "baby trades"). Only starts trailing once the trade
# is >= EXEC_TRAIL_ACTIVATE_R in profit. Partial-close fractions must sum to 100;
# a smaller TP1 / bigger TP3 = bigger runner.
EXEC_TRAIL_BUFFER_ATR=0.5
EXEC_TRAIL_ACTIVATE_R=1.0
EXEC_TP1_PCT=30
EXEC_TP2_PCT=30
EXEC_TP3_PCT=40

# --- Service runtime (stream-connected services) ---
# data-collector replay source (CONNECTOR_MODE=replay).
REPLAY_SOURCE=data/sample/xauusd_m1_sample.parquet
# Seconds between replayed bars. 0 = as fast as possible.
REPLAY_SPEED_SECONDS=0
# Restart the replay from the top after exhausting the source (else idle).
REPLAY_LOOP=false
# feature-engine: bars fetched from the connector at startup (live mode only).
WARMUP_BARS=500
# Upper bound on the feature-engine's in-memory bar buffer.
MAX_HISTORY_BARS=200000
# Consumer XREADGROUP block timeout (ms) and batch size per iteration.
STREAM_BLOCK_MS=1000
STREAM_BATCH_SIZE=64

# --- Misc ---
LOG_LEVEL=INFO
ENVIRONMENT=development

# --- Web-Dashboard (Block 9) ---
# Enable/disable the Custom Web-Dashboard. Default off — must be
# explicitly true to serve traffic on 127.0.0.1:8080.
# See AGENTS.md §4j for the full list of dashboard caveats.
DASHBOARD_ENABLED=false
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8080
# Host interface the compose dashboard service publishes its port on.
# 127.0.0.1 = loopback only (default, safe). Set 0.0.0.0 for LAN access
# on a TRUSTED network only. Prefer an SSH tunnel for remote access.
DASHBOARD_BIND_HOST=127.0.0.1
# Generate bcrypt hash with:
#   .venv/bin/python -c "import bcrypt; print(bcrypt.hashpw(b'my_pw', bcrypt.gensalt()).decode())"
# Roles: viewer (read-only), operator (approve proposals + backtest), admin (Live-Mode-Toggle)
DASHBOARD_USERS={"lucas": {"password_hash": "$2b$12$...", "role": "admin"}}
DASHBOARD_SESSION_TTL_SECONDS=28800
# Dashboard sessions live on Redis DB 1, trading streams stay on /0.
DASHBOARD_REDIS_URL=redis://redis:6379/1
DASHBOARD_REDIS_STREAMS_URL=redis://redis:6379/0
# Set true to enable the Live-Mode-Toggle button (admin role required).
DASHBOARD_LIVE_MODE_ENABLED=false
